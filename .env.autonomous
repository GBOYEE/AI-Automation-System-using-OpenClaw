# Xander Autonomous Service Environment
# Copy to .env and fill in

# Telegram credentials (required)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_DEFAULT_CHAT_ID=your_chat_id_here

# Operator mode: cli (local) or api (remote)
OPERATOR_MODE=cli
OPERATOR_API_URL=http://localhost:8001

# Task queue location (SQLite)
TASK_QUEUE_PATH=/data/tasks.db

# Logging
LOG_LEVEL=INFO
